{
	"namespace": "sm.item",
	"doc": {
		"text": [
			"Allows checking for static infortmation about items."
		]
	},
	"constants": [
		{
			"name": "trackingType",
			"doc": {
				"text": [
					"Item tracking filter types",
					"@table",
					"mainQuest",
					"sideQuest",
					"researchable",
					"@table"
				],
				"return": [
					[
						"table",
						"The item tracking types list."
					]
				]
			}
		}
	],
	"functions": [
		{
			"name": "addTrackedItem",
			"doc": {
				"text": [
					"Adds a shape uuid to be a tracked item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The uuid of the shape."
					],
					[
						"integer",
						"type",
						"The [sm.item.trackingType]."
					]
				],
				"client_only": true
			}
		},
		{
			"name": "getBuoyancyRating",
			"doc": {
				"text": [
					"Returns the buoyancy rating of an item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"integer",
						"The buoyancy."
					]
				]
			}
		},
		{
			"name": "getCharacterShape",
			"doc": {
				"text": [
					"Return the data for the character [Shape]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"table",
						"The character shape data."
					]
				]
			}
		},
		{
			"name": "getDensityRating",
			"doc": {
				"text": [
					"Returns the density rating of an item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"integer",
						"The density."
					]
				]
			}
		},
		{
			"name": "getDurabilityRating",
			"doc": {
				"text": [
					"Returns the durability rating of an item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"integer",
						"The durability."
					]
				]
			}
		},
		{
			"name": "getEdible",
			"doc": {
				"text": [
					"Return the data for the edible [Shape]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"table",
						"The edible data."
					]
				]
			}
		},
		{
			"name": "getFeatureData",
			"doc": {
				"text": [
					"Returns the shapes feature data."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"table",
						"The feature data table"
					]
				]
			}
		},
		{
			"name": "getFrictionRating",
			"doc": {
				"text": [
					"Returns the friction rating of an item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"integer",
						"The friction."
					]
				]
			}
		},
		{
			"name": "getInteractablesUuidsOfType",
			"doc": {
				"text": [
					"Returns a table of all [Interactable, interactable] [Uuid, uuids] of a interactable type"
				],
				"params": [
					[
						"string",
						"interactableType",
						"The interactable type name"
					]
				],
				"return": [
					[
						"table",
						"table of interactable [Uuid, uuids] {[Uuid], ..}"
					]
				]
			}
		},
		{
			"name": "getMaterial",
			"doc": {
				"text": [
					"Returns the material of a shape uuid."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The uuid of the shape."
					]
				],
				"return": [
					[
						"string",
						"The shape's material."
					]
				]
			}
		},
		{
			"name": "getMaterialId",
			"doc": {
				"text": [
					"Returns the material id of a shape uuid."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The uuid of the shape."
					]
				],
				"return": [
					[
						"integer",
						"The shape's material id."
					]
				]
			}
		},
		{
			"name": "getPlantable",
			"doc": {
				"text": [
					"Return the data for the plantable [Shape]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"table",
						"The plantable data."
					]
				]
			}
		},
		{
			"name": "getPlantableUuids",
			"doc": {
				"text": [
					"Returns a table of all plantable [Uuid, uuids]."
				],
				"return": [
					[
						"table",
						"table of all plantable [Uuid, uuids] {[Uuid], ..}."
					]
				]
			}
		},
		{
			"name": "getQualityLevel",
			"doc": {
				"text": [
					"Return the quality level for the [Shape]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"integer",
						"The quality level."
					]
				]
			}
		},
		{
			"name": "getShapeDefaultColor",
			"doc": {
				"text": [
					"Returns the default color of a shape"
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"[Color]",
						"Color of the shape."
					]
				]
			}
		},
		{
			"name": "getShapeOffset",
			"doc": {
				"text": [
					"Return the [Shape] offset"
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"[Vec3]",
						"The offset vector."
					]
				]
			}
		},
		{
			"name": "getShapeRotation",
			"doc": {
				"text": [
					"Gets the shape local rotation given a shape rotation index and a surface normal in local space (unit axis vector)."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					],
					[
						"integer",
						"rotationIndex?",
						"The rotation index to get the rotation for. (Defaults to 0)"
					],
					[
						"[Vec3]",
						"localNormal?",
						"The local space normal the is considered to be placed on. (Defaults to positive Z axis)"
					]
				],
				"return": [
					[
						"[Quat]",
						"The local shape rotation."
					]
				]
			}
		},
		{
			"name": "getShapeSize",
			"doc": {
				"text": [
					"Returns the block dimensions of an shape. Returns nil if the uuid is not an item."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"[Vec3]",
						"Size of the shape."
					]
				]
			}
		},
		{
			"name": "getStackSize",
			"doc": {
				"text": [
					"Return the stack size for the item. Returns the default stack size of 1 if the item is not found or is a Tool."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"integer",
						"The stack size."
					]
				]
			}
		},
		{
			"name": "isBlock",
			"doc": {
				"text": [
					"Check if the item is a block."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if the item is a block."
					]
				]
			}
		},
		{
			"name": "isFlammable",
			"doc": {
				"text": [
					"Returns whether the item is flammable."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if flammable."
					]
				]
			}
		},
		{
			"name": "isHarvestablePart",
			"doc": {
				"text": [
					"Return whether the [Shape] uuid belongs to a harvestable shape."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The shape uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if shape is a harvestable shape."
					]
				]
			}
		},
		{
			"name": "isJoint",
			"doc": {
				"text": [
					"Check if the item is a [Joint]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if the item is a joint."
					]
				]
			}
		},
		{
			"name": "isPart",
			"doc": {
				"text": [
					"Check if the item is a part."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The item uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if the item is a part."
					]
				]
			}
		},
		{
			"name": "isTool",
			"doc": {
				"text": [
					"Check if the item uuid belongs to a [Tool]."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The uuid."
					]
				],
				"return": [
					[
						"boolean",
						"True if the item uuid belongs to a tool."
					]
				]
			}
		},
		{
			"name": "removeTrackedItem",
			"doc": {
				"text": [
					"Removes a shape uuid from the tracked items."
				],
				"params": [
					[
						"[Uuid]",
						"uuid",
						"The uuid of the shape."
					],
					[
						"integer",
						"type",
						"The [sm.item.trackingType]."
					]
				],
				"client_only": true
			}
		}
	]
}