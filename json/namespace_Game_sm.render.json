			"name": "setReflectionLevelColor",
			"doc": {
				"text": [
					"Sets the reflection color correction settings for one reflection level."
				],
				"params": [
					[
						"string",
						"settingsLevel",
						"Off/Low/Medium/High."
					],
					[
						"number",
						"min",
						"Color min."
					],
					[
						"number",
						"max",
						"Color max."
					],
					[
						"number",
						"mul",
						"Color mul."
					]
				],
				"client_only": true
			}
		},
		{
			"name": "setVolumetricFog",
			"doc": {
				"text": [
					"Sets the Volumetric fog override settings."
				],
				"params": [
					[
						"number",
						"min",
						"Fog min."
					],
					[
						"number",
						"max",
						"Fog max."
					],
					[
						"number",
						"loopSpeed",
						"Fog loop speed."
					],
					[
						"[Vec3]",
						"scrollSpeed",
						"Fog scroll speed."
					],
					[
						"[Vec3]",
						"scale",
						"Fog scale."
					],
					[
						"number",
						"intensity",
						"Fog intensity."
					]
				],
				"client_only": true
			}
