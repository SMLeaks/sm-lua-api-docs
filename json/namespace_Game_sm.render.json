				"return": [
					[
						"table",
						"The default horizon light render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultReflectionColor",
			"doc": {
				"text": [
					"Gets a table of the default reflection color render settings."
				],
				"return": [
					[
						"table",
						"The default reflection color render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultVolumetricFog",
			"doc": {
				"text": [
					"Gets a table of the default Volumetric fog render settings."
				],
				"return": [
					[
						"table",
						"The default Volumetric fog render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultVoxelLODBoost",
			"doc": {
				"text": [
					"Gets the default voxel LOD boost render setting."
				],
				"return": [
					[
						"number",
						"The default voxel LOD boost render setting."
					]
				]
			}
		},
		{
			"name": "getDrawDistance",
			"doc": {
				"text": [
					"Gets the draw distance."
				],
				"return": [
					[
						"number",
						"The draw distance."
					]
				],
				"client_only": true
			}
		},
		{
			"name": "getOutdoorLighting",
			"doc": {
				"text": [
					"Gets the lighting cycle fraction."
				],
				"return": [
					[
						"number",
						"The fraction of the day cycle lighting."
					]
				],
				"client_only": true
			}
		},
		{
			"name": "getScreenCoordinatesFromWorldPosition",
			"doc": {
				"text": [
					"Return the screen coordinates that align with the given world position."
				],
				"params": [
					[
						"[Vec3]",
						"pos",
						"World position to align"
					],
					[
						"integer",
						"width",
						"Screen width"
					],
					[
						"integer",
						"height",
						"Screen height"
					]
				],
				"return": [
					[
						"number, number",
						"The x and y screen coordinates."
					]
				]
			}
		},
		{
			"name": "isOutdoor",
			"doc": {
				"text": [
					"Checks if client is outdoor"
				],
				"return": [
					[
						"boolean",
						"True if local client is outdoor."
					]
				],
				"client_only": true
			}
		},
		{
			"name": "resetAllReflectionColor",
			"doc": {
				"text": [
					"Resets all the reflection color settings."
				],
				"client_only": true
			}
		},
		{
			"name": "resetCameraLight",
			"doc": {
				"text": [
					"Resets the camera light override settings."
				]
			}
		},
		{
			"name": "resetFog",
			"doc": {
				"text": [
					"Resets the fog override settings."
				],
				"client_only": true
			}
		},
		{
			"name": "resetGI",
			"doc": {
				"text": [
					"Resets the global illumination override settings."
				],
				"client_only": true
			}
		},
		{
			"name": "resetHorizonLight",
			"doc": {
				"text": [
					"Resets the Horizon light settings."
				],
				"client_only": true
