					],
					[
						"number",
						"verticalFadeDistance",
						"Vertical fog fade distance.  (Optional)"
					],
					[
						"number",
						"verticalFalloff",
						"Vertical fog falloff.  (Optional)"
					],
					[
						"number",
						"verticalStart",
						"Vertical fog start distance.  (Optional)"
					],
					[
						"number",
						"verticalEnd",
						"Vertical fog end distance.  (Optional)"
					],
					[
						"[Color]",
						"verticalStartColor",
						"Vertical fog start color.  (Optional)"
					],
					[
						"[Color]",
						"verticalEndColor",
						"Vertical fog end color.  (Optional)"
					],
					[
						"number",
						"fadeDistance",
						"Fog fade distance. (Optional)"
					]
				],
				"client_only": true
			}
