{
	"namespace": "sm.render",
	"doc": {
		"text": [
			"Render settings"
		]
	},
	"constants": [],
	"functions": [
		{
			"name": "getDefaultCameraLight",
			"doc": {
				"text": [
					"Gets a table of the default camera light render settings."
				],
				"return": [
					[
						"table",
						"The default camera light render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultFog",
			"doc": {
				"text": [
					"Gets a table of the default fog render settings."
				],
				"return": [
					[
						"table",
						"The default fog render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultGI",
			"doc": {
				"text": [
					"Gets a table of the default GI render settings."
				],
				"return": [
					[
						"table",
						"The default GI render settings."
					]
				]
			}
		},
		{
			"name": "getDefaultHorizonLight",
			"doc": {
				"text": [
					"Gets a table of the default horizon light render settings."
