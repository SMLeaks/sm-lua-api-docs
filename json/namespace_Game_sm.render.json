			"name": "resetVoxelLODBoost",
			"doc": {
				"text": [
					"Resets the voxel terrain LOD boost override setting."
				],
				"client_only": true
			}
		},
		{
			"name": "setCameraLight",
			"doc": {
				"text": [
					"Sets the camera light override settings.",
					"Optionally sets far camera light settings (used for camera pullback lerp)."
				],
				"params": [
					[
						"number",
						"intensity",
						"The light intensity."
					],
					[
						"number",
						"range",
						"Light range."
					],
					[
						"[Color]",
						"color",
						"Light color."
					],
					[
						"number",
						"farIntensity?",
						"Far light intensity. (Optional)"
					],
					[
						"number",
						"farRange?",
						"Far light range. (Optional)"
					],
					[
						"[Color]",
						"farColor?",
						"Far light color. (Optional)"
					]
				],
				"client_only": true
			}
		},
		{
			"name": "setCinematic",
			"doc": {
				"text": [
					"Sets if a cinematic is playing"
				],
				"params": [
					[
						"boolean",
						"cinematic",
						"If true, sets to cinematic"
					]
				],
				"client_only": true
			}
		},
		{
			"name": "setCloudSettings",
			"doc": {
				"text": [
					"Sets the cloud settings."
				],
				"params": [
					[
						"number",
						"coverage",
						"The fraction of the cloud coverage."
					],
					[
						"number",
						"height",
						"The cloud height."
					],
					[
						"number",
						"radius",
						"The atmosphere radius."
					],
					[
						"number",
						"tallnessScale",
						"The tallness scale(0.1 - 4.0)."
					],
					[
						"number",
						"directionalLightMod",
						"Directional light mod (0.0 - 1.0)."
					],
					[
						"[Vec3]",
						"scroll",
						"Cloud scroll."
					],
					[
						"[Vec3]",
						"scrollRotation",
						"Cloud scroll rotation."
					]
				],
				"client_only": true
			}
		},
